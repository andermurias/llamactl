# ── Large model files ─────────────────────────────────────────────────────────
models/**/*.gguf
models/**/*.bin
models/**/*.safetensors
models/**/*.pt
models/**/*.pth

# Keep directory structure (empty dirs needed by installer)
!models/chat/.gitkeep
!models/embeddings/.gitkeep

# ── Runtime files ─────────────────────────────────────────────────────────────
logs/*.log
logs/*.pid

# Keep logs directory
!logs/.gitkeep

# ── Third-party repos — cloned fresh by install.sh ───────────────────────────
# Not tracked: they're third-party repos; our launcher scripts are tracked.
Kokoro-FastAPI/

# ── ComfyUI — cloned fresh by llamactl comfyui install / install.sh ──────────
# The ComfyUI directory itself is not tracked (large, third-party code).
# Models placed inside it are downloaded by the user post-install.
ComfyUI/
!llamactl/cmd/comfyui/
!llamactl/internal/comfyui/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
