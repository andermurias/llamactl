#!/usr/bin/env bash
# llamactl — llama-swap + ComfyUI service manager
# Usage: llamactl [--verbose] <command> [options]
# Commands: start, stop, restart, status, enable, disable, install, uninstall, logs, upgrade, version, models, help
#           comfyui <start|stop|status|logs>

set -euo pipefail

# ── llama-swap configuration ──────────────────────────────────────────────────

LABEL="com.llamastack.llama-swap"
PLIST_PATH="$HOME/Library/LaunchAgents/${LABEL}.plist"
AI_DIR="$HOME/AI"
CONFIG="$AI_DIR/llama-swap.yaml"
LLAMA_SWAP="/opt/homebrew/bin/llama-swap"
LOG_DIR="$AI_DIR/logs"
LOG_FILE="$LOG_DIR/llama-swap.log"
LISTEN="127.0.0.1:8080"
USER_ID=$(id -u)
SERVICE_TARGET="gui/${USER_ID}/${LABEL}"

# ── ComfyUI configuration ─────────────────────────────────────────────────────

COMFYUI_DIR="$AI_DIR/ComfyUI"
COMFYUI_PYTHON="$COMFYUI_DIR/.venv/bin/python"
COMFYUI_PORT="8188"
COMFYUI_LOG="$LOG_DIR/comfyui.log"

# ── Colours ──────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
  BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; RESET=''
fi

# ── Logging helpers ──────────────────────────────────────────────────────────

VERBOSE=false

log()     { echo -e "$*"; }
info()    { echo -e "${BLUE}→${RESET} $*"; }
ok()      { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*"; }
err()     { echo -e "${RED}✗${RESET} $*" >&2; }
verbose() { $VERBOSE && echo -e "  ${RESET}$*" || true; }

# ── Argument parsing ─────────────────────────────────────────────────────────

while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -v|--verbose) VERBOSE=true; shift ;;
    -h|--help)    CMD="help"; break ;;
    --) shift; break ;;
    *) err "Unknown flag: $1"; echo "Run 'llamactl help' for usage." >&2; exit 1 ;;
  esac
done

CMD="${1:-help}"; shift 2>/dev/null || true

# ── launchd helpers ──────────────────────────────────────────────────────────

is_loaded() {
  launchctl print "$SERVICE_TARGET" &>/dev/null
}

is_running() {
  launchctl print "$SERVICE_TARGET" 2>/dev/null | grep -q "state = running"
}

get_pid() {
  launchctl print "$SERVICE_TARGET" 2>/dev/null \
    | grep -E '^\s+pid = ' | awk '{print $NF}' | tr -d '[:space:]' || true
}

get_exit_status() {
  launchctl print "$SERVICE_TARGET" 2>/dev/null \
    | grep -E 'last exit' | awk '{print $NF}' | tr -d '[:space:]' || echo "?"
}

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

# ── ComfyUI (PID-managed, manual start — NOT a launchd service) ───────────────
# ComfyUI uses ~6 GB for image models; run it on demand to preserve RAM for LLMs.
# Start with: llamactl comfyui start
# Stop  with: llamactl comfyui stop

COMFYUI_PID_FILE="$LOG_DIR/comfyui.pid"

comfyui_get_pid() {
  if [[ -f "$COMFYUI_PID_FILE" ]]; then
    cat "$COMFYUI_PID_FILE" 2>/dev/null | tr -d '[:space:]' || true
  fi
}

comfyui_is_running() {
  local pid; pid=$(comfyui_get_pid)
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

cmd_comfyui() {
  local subcmd="${1:-status}"; shift 2>/dev/null || true

  case "$subcmd" in
    start)
      if ! [[ -d "$COMFYUI_DIR" ]]; then
        err "ComfyUI not found at $COMFYUI_DIR"
        err "Run: git clone https://github.com/comfyanonymous/ComfyUI $COMFYUI_DIR"
        exit 1
      fi
      if ! [[ -f "$COMFYUI_PYTHON" ]]; then
        err "ComfyUI venv not found at $COMFYUI_PYTHON"
        err "Run the installer: $AI_DIR/scripts/install.sh"
        exit 1
      fi
      if comfyui_is_running; then
        warn "ComfyUI is already running (PID $(comfyui_get_pid))"
        return 0
      fi

      ensure_log_dir
      info "Starting ComfyUI on port ${COMFYUI_PORT}…"
      "$COMFYUI_PYTHON" "$COMFYUI_DIR/main.py" \
        --listen 0.0.0.0 --port "$COMFYUI_PORT" \
        >> "$COMFYUI_LOG" 2>&1 &
      local pid=$!
      echo "$pid" > "$COMFYUI_PID_FILE"

      local i=0
      while ! curl -sf --max-time 3 "http://127.0.0.1:${COMFYUI_PORT}" -o /dev/null \
            && (( i < 30 )); do sleep 2; (( i++ )); done

      if comfyui_is_running; then
        ok "ComfyUI started  (PID $pid)"
        info "UI  → http://$(ipconfig getifaddr en0 2>/dev/null || echo '127.0.0.1'):${COMFYUI_PORT}"
        info "Log → $COMFYUI_LOG"
        warn "Remember to stop ComfyUI before loading large LLMs — they share the same memory pool."
      else
        err "ComfyUI failed to start — check logs: $COMFYUI_LOG"
        rm -f "$COMFYUI_PID_FILE"
        exit 1
      fi
      ;;

    stop)
      if ! comfyui_is_running; then
        warn "ComfyUI is not running"
        rm -f "$COMFYUI_PID_FILE"
        return 0
      fi
      local pid; pid=$(comfyui_get_pid)
      info "Stopping ComfyUI (PID $pid)…"
      kill "$pid" 2>/dev/null || true
      local i=0
      while comfyui_is_running && (( i < 10 )); do sleep 1; (( i++ )); done
      if comfyui_is_running; then
        kill -9 "$pid" 2>/dev/null || true
      fi
      rm -f "$COMFYUI_PID_FILE"
      ok "ComfyUI stopped"
      ;;

    status)
      echo ""
      echo -e "  ${BOLD}ComfyUI${RESET}"
      if comfyui_is_running; then
        local pid; pid=$(comfyui_get_pid)
        local uptime; uptime=$(ps -p "$pid" -o etime= 2>/dev/null | tr -d ' ' || echo "?")
        echo -e "  Status:   ${GREEN}running${RESET}  (PID $pid, uptime $uptime)"
        echo -e "  UI:       http://$(ipconfig getifaddr en0 2>/dev/null || echo 'localhost'):${COMFYUI_PORT}"
      else
        echo -e "  Status:   ${YELLOW}stopped${RESET}  (manual service — start with: llamactl comfyui start)"
      fi
      echo -e "  Dir:      $COMFYUI_DIR"
      echo -e "  Log:      $COMFYUI_LOG"
      echo ""
      ;;

    logs)
      local follow=false
      for arg in "$@"; do [[ "$arg" == "-f" || "$arg" == "--follow" ]] && follow=true; done
      if $follow; then
        tail -n 50 -f "$COMFYUI_LOG" 2>/dev/null || { warn "No ComfyUI log yet"; exit 1; }
      else
        [[ -f "$COMFYUI_LOG" ]] && tail -n 100 "$COMFYUI_LOG" || warn "No ComfyUI log yet"
      fi
      ;;

    help|--help|-h)
      echo ""
      echo -e "  ${BOLD}llamactl comfyui${RESET} — ComfyUI image generation (manual, on-demand)"
      echo ""
      echo "  start       Start ComfyUI (port ${COMFYUI_PORT})"
      echo "  stop        Stop ComfyUI and free memory"
      echo "  status      Show status and URL"
      echo "  logs        Show last 100 lines of ComfyUI logs"
      echo "  logs -f     Follow ComfyUI logs in real time"
      echo ""
      echo -e "  ${YELLOW}⚠  ComfyUI uses ~6 GB for image models — always stop it before loading large LLMs.${RESET}"
      echo ""
      ;;

    *)
      err "Unknown comfyui command: '$subcmd'"
      echo "  Usage: llamactl comfyui <start|stop|status|logs>" >&2
      exit 1
      ;;
  esac
}

# ── Models ───────────────────────────────────────────────────────────────────

cmd_models() {
  echo ""
  local models_resp running_resp
  models_resp=$(curl -s --max-time 3 "http://${LISTEN}/v1/models" 2>/dev/null || echo "")
  running_resp=$(curl -s --max-time 3 "http://${LISTEN}/running" 2>/dev/null || echo "")

  if [[ -n "$models_resp" ]]; then
    MODELS_JSON="$models_resp" RUNNING_JSON="$running_resp" python3 -c "
import json, os, sys

models_raw  = os.environ.get('MODELS_JSON', '')
running_raw = os.environ.get('RUNNING_JSON', '')
tty = sys.stdout.isatty()
GREEN  = '\033[0;32m' if tty else ''
RESET  = '\033[0m'    if tty else ''

model_ids = []
try:
    data = json.loads(models_raw)
    lst  = data.get('data', []) if isinstance(data, dict) else data
    model_ids = [m.get('id', str(m)) if isinstance(m, dict) else str(m) for m in lst]
except Exception as e:
    print(f'    (parse error: {e})')

running_ids = set()
if running_raw:
    try:
        rd = json.loads(running_raw)
        rm = rd if isinstance(rd, list) else rd.get('models', rd.get('running', []))
        running_ids = set(
            m.get('id', m.get('name', str(m))) if isinstance(m, dict) else str(m)
            for m in rm
        )
    except:
        pass

print(f'  Available models ({len(model_ids)}):')
for mid in model_ids:
    if mid in running_ids:
        print(f'    {GREEN}●{RESET} {mid:<32} [loaded]')
    else:
        print(f'    ○ {mid}')
" 2>/dev/null || echo "    (unavailable)"
  else
    echo -e "  ${YELLOW}⚠${RESET}  llama-swap not responding at http://${LISTEN}"
    echo "  Start it first: llamactl start"
  fi

  echo ""
  echo -e "  ${BOLD}GGUF models (local ~/AI/models/):${RESET}"
  local found_gguf=false
  while IFS= read -r f; do
    found_gguf=true
    local size; size=$(du -sh "$f" 2>/dev/null | awk '{print $1}')
    echo -e "    ${GREEN}✓${RESET} $(basename "$f")  (${size})"
  done < <(find "$AI_DIR/models" -name "*.gguf" 2>/dev/null | sort)
  $found_gguf || echo "    (none found)"

  echo ""
  echo -e "  ${BOLD}MLX/HF model cache (~/.cache/huggingface/hub/):${RESET}"
  local hf_cache="$HOME/.cache/huggingface/hub"
  if [[ -d "$hf_cache" ]]; then
    local total; total=$(du -sh "$hf_cache" 2>/dev/null | awk '{print $1}')
    echo "    Total: ${total}"
    local cached; cached=$(ls "$hf_cache" 2>/dev/null \
      | grep "^models--" | sed 's/^models--.*--//' \
      | sort | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
    [[ -n "$cached" ]] && echo "    ${cached}"
  else
    echo "    (no HuggingFace cache found)"
  fi
  echo ""
}

# ── Plist writer ─────────────────────────────────────────────────────────────

write_plist() {
  local autostart="${1:-false}"
  ensure_log_dir
  cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LABEL}</string>

    <key>ProgramArguments</key>
    <array>
        <string>${LLAMA_SWAP}</string>
        <string>--config</string>
        <string>${CONFIG}</string>
        <string>--listen</string>
        <string>${LISTEN}</string>
        <string>--watch-config</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>${HOME}</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>${AI_DIR}</string>

    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>

    <!-- Only auto-restart on crashes, not on intentional SIGTERM stops -->
    <key>KeepAlive</key>
    <dict>
        <key>Crashed</key>
        <true/>
    </dict>

    <!-- Minimum 10 s between restart attempts to avoid tight crash loops -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>RunAtLoad</key>
    <${autostart}/>
</dict>
</plist>
PLIST
  verbose "Plist written to $PLIST_PATH (RunAtLoad=${autostart})"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
  if [[ ! -f "$LLAMA_SWAP" ]]; then
    err "llama-swap not found at $LLAMA_SWAP"
    err "Install with: brew install llama-swap  or  $AI_DIR/scripts/install-llama-swap.sh"
    exit 1
  fi
  if [[ ! -f "$CONFIG" ]]; then
    err "Config not found at $CONFIG"
    exit 1
  fi
  write_plist false
  if is_loaded; then
    verbose "Service already loaded — reloading to pick up plist changes"
    launchctl bootout "gui/${USER_ID}" "$PLIST_PATH" 2>/dev/null || \
      launchctl bootout "$SERVICE_TARGET" 2>/dev/null || true
    sleep 1
  fi
  launchctl bootstrap "gui/${USER_ID}" "$PLIST_PATH"
  ok "LaunchAgent installed (auto-start at login: disabled)"
  info "Run 'llamactl enable' to auto-start at every login"
}

cmd_start() {
  if ! [[ -f "$PLIST_PATH" ]]; then
    verbose "Plist not found — installing service first"
    cmd_install
  elif ! is_loaded; then
    launchctl bootstrap "gui/${USER_ID}" "$PLIST_PATH"
    verbose "Service bootstrapped into launchd"
  fi

  if is_running; then
    warn "llama-swap is already running (PID $(get_pid))"
    return 0
  fi

  launchctl kickstart "gui/${USER_ID}/${LABEL}"
  local i=0
  while ! is_running && (( i < 8 )); do sleep 1; (( i++ )); done

  if is_running; then
    ok "llama-swap started  (PID $(get_pid))"
    info "API → http://${LISTEN}/v1"
    info "UI  → http://${LISTEN}"
  else
    err "llama-swap failed to start"
    err "Check logs: llamactl logs"
    exit 1
  fi
}

cmd_stop() {
  if ! is_loaded; then
    warn "Service not loaded — nothing to stop"
    return 0
  fi
  if ! is_running; then
    warn "llama-swap is not running"
    return 0
  fi

  local pid; pid=$(get_pid)
  verbose "Sending SIGTERM to PID $pid"
  launchctl kill SIGTERM "$SERVICE_TARGET" 2>/dev/null || true

  local i=0
  while is_running && (( i < 15 )); do sleep 1; (( i++ )); done

  if is_running; then
    warn "Process did not stop gracefully — sending SIGKILL"
    launchctl kill SIGKILL "$SERVICE_TARGET" 2>/dev/null || true
    sleep 2
  fi

  ok "llama-swap stopped"
}

cmd_restart() {
  info "Restarting llama-swap…"
  cmd_stop
  sleep 1
  cmd_start
}

cmd_status() {
  echo ""
  echo -e "  ${BOLD}llama-swap${RESET}"

  if [[ ! -f "$PLIST_PATH" ]]; then
    echo -e "  Status:     ${YELLOW}not installed${RESET}"
    echo ""
    echo -e "  Run ${BOLD}llamactl install${RESET} or ${BOLD}llamactl start${RESET} to set up the service."
    echo ""
    return
  fi

  if ! is_loaded; then
    echo -e "  Status:     ${RED}not loaded${RESET}"
    echo -e "  Plist:      $PLIST_PATH"
    echo ""
    return
  fi

  local pid; pid=$(get_pid)

  if [[ -n "$pid" && "$pid" -gt 0 ]] 2>/dev/null; then
    local uptime; uptime=$(ps -p "$pid" -o etime= 2>/dev/null | tr -d ' ' || echo "?")
    echo -e "  Status:     ${GREEN}running${RESET}  (PID $pid, uptime $uptime)"
  else
    local exit_s; exit_s=$(get_exit_status)
    echo -e "  Status:     ${RED}stopped${RESET}  (last exit: $exit_s)"
  fi

  local autostart; autostart=$(/usr/libexec/PlistBuddy -c "Print :RunAtLoad" "$PLIST_PATH" 2>/dev/null || echo "false")
  if [[ "$autostart" == "true" ]]; then
    echo -e "  Auto-start: ${GREEN}enabled${RESET}  (starts at login)"
  else
    echo -e "  Auto-start: ${YELLOW}disabled${RESET}  (run 'llamactl enable' to activate)"
  fi

  echo -e "  API:        http://${LISTEN}/v1"
  echo -e "  UI:         http://${LISTEN}"
  echo -e "  Config:     $CONFIG"
  echo -e "  Log:        $LOG_FILE"

  # Loaded models
  echo ""
  echo -e "  ${BOLD}Loaded models:${RESET}"
  local resp
  resp=$(curl -s --max-time 3 "http://${LISTEN}/running" 2>/dev/null || echo "")
  if [[ -n "$resp" ]]; then
    echo "$resp" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    models = data if isinstance(data, list) else data.get('models', data.get('running', []))
    if models:
        for m in models:
            name = m.get('id', m.get('name', str(m))) if isinstance(m, dict) else str(m)
            print(f'    ● {name}')
    else:
        print('    (none — models load on first request)')
except Exception as e:
    print(f'    (parse error: {e})')
" 2>/dev/null || echo "    (unavailable)"
  else
    echo "    (service not responding)"
  fi

  echo ""

  # ComfyUI inline status
  echo -e "  ${BOLD}ComfyUI${RESET}"
  if comfyui_is_running; then
    local cpid; cpid=$(comfyui_get_pid)
    local cuptime; cuptime=$(ps -p "$cpid" -o etime= 2>/dev/null | tr -d ' ' || echo "?")
    echo -e "  ComfyUI:    ${GREEN}running${RESET}  (PID $cpid, uptime $cuptime) → http://$(ipconfig getifaddr en0 2>/dev/null || echo 'localhost'):${COMFYUI_PORT}"
  else
    echo -e "  ComfyUI:    ${YELLOW}stopped${RESET}  (run 'llamactl comfyui start' to enable image generation)"
  fi

  echo ""
}

cmd_enable() {
  if [[ ! -f "$LLAMA_SWAP" ]]; then
    err "llama-swap not found at $LLAMA_SWAP"; exit 1
  fi

  write_plist true

  # Reload so launchd picks up RunAtLoad=true
  if is_loaded; then
    launchctl bootout "gui/${USER_ID}" "$PLIST_PATH" 2>/dev/null || \
      launchctl bootout "$SERVICE_TARGET" 2>/dev/null || true
    sleep 1
  fi
  launchctl bootstrap "gui/${USER_ID}" "$PLIST_PATH"

  if ! is_running; then
    launchctl kickstart "gui/${USER_ID}/${LABEL}"
    local i=0
    while ! is_running && (( i < 8 )); do sleep 1; (( i++ )); done
  fi

  if is_running; then
    ok "llama-swap enabled — starts automatically at login  (PID $(get_pid))"
  else
    warn "Auto-start enabled but service didn't start — check: llamactl logs"
  fi
}

cmd_disable() {
  if [[ ! -f "$PLIST_PATH" ]]; then
    warn "Service not installed"; return 0
  fi

  write_plist false

  # Reload plist so launchd records the RunAtLoad=false change
  if is_loaded; then
    launchctl bootout "gui/${USER_ID}" "$PLIST_PATH" 2>/dev/null || \
      launchctl bootout "$SERVICE_TARGET" 2>/dev/null || true
    sleep 1
    launchctl bootstrap "gui/${USER_ID}" "$PLIST_PATH"
  fi

  ok "Auto-start at login disabled"
  warn "Service is still available — use 'llamactl stop' to stop it now"
}

cmd_uninstall() {
  cmd_stop 2>/dev/null || true
  if is_loaded; then
    launchctl bootout "gui/${USER_ID}" "$PLIST_PATH" 2>/dev/null || \
      launchctl bootout "$SERVICE_TARGET" 2>/dev/null || true
  fi
  rm -f "$PLIST_PATH"
  ok "Service uninstalled (logs and config preserved)"
}

cmd_logs() {
  ensure_log_dir
  local follow=false
  for arg in "$@"; do
    [[ "$arg" == "-f" || "$arg" == "--follow" ]] && follow=true
  done

  if $follow; then
    info "Following logs — Ctrl+C to stop"
    tail -n 50 -f "$LOG_FILE" 2>/dev/null || { warn "Log file not found yet: $LOG_FILE"; exit 1; }
  else
    if [[ ! -f "$LOG_FILE" ]]; then
      warn "No log file yet — start the service first: llamactl start"
      exit 1
    fi
    tail -n 100 "$LOG_FILE"
  fi
}

cmd_upgrade() {
  local script; script="$(dirname "$(realpath "$0")")/install-llama-swap.sh"
  if [[ ! -f "$script" ]]; then
    err "Upgrade script not found: $script"
    info "Alternatively run: brew upgrade llama-swap"
    exit 1
  fi
  info "Upgrading llama-swap…"
  bash "$script"
  if is_running; then
    info "Restarting service to apply upgrade…"
    cmd_restart
  fi
  ok "Upgrade complete"
}

cmd_version() {
  if [[ -f "$LLAMA_SWAP" ]]; then
    "$LLAMA_SWAP" -version 2>/dev/null || "$LLAMA_SWAP" --version 2>/dev/null || echo "version unknown"
  else
    err "llama-swap not found at $LLAMA_SWAP"
    exit 1
  fi
}

cmd_help() {
  echo ""
  echo -e "  ${BOLD}llamactl${RESET} — llama-swap AI inference service manager"
  echo ""
  echo -e "  ${BOLD}USAGE${RESET}"
  echo "    llamactl [--verbose] <command> [options]"
  echo ""
  echo -e "  ${BOLD}SERVICE CONTROL${RESET}"
  echo "    start       Start the service (installs plist automatically)"
  echo "    stop        Stop the service"
  echo "    restart     Stop then start"
  echo "    status      Show status, PID, uptime, loaded models, and ComfyUI"
  echo ""
  echo -e "  ${BOLD}AUTO-START (login item)${RESET}"
  echo "    enable      Install + start + auto-start at every login"
  echo "    disable     Disable auto-start (service stays running)"
  echo "    install     Install launchd plist without starting"
  echo "    uninstall   Remove launchd plist completely"
  echo ""
  echo -e "  ${BOLD}IMAGE GENERATION (on-demand)${RESET}"
  echo "    comfyui start    Start ComfyUI on port ${COMFYUI_PORT} (uses ~6 GB)"
  echo "    comfyui stop     Stop ComfyUI and free memory"
  echo "    comfyui status   Show ComfyUI status and URL"
  echo "    comfyui logs     Show ComfyUI logs  (-f to follow)"
  echo ""
  echo -e "  ${BOLD}LOGS & MAINTENANCE${RESET}"
  echo "    logs        Show last 100 lines of llama-swap logs"
  echo "    logs -f     Follow logs in real time"
  echo "    models      Show available models and download status"
  echo "    upgrade     Update llama-swap binary to latest release"
  echo "    version     Show llama-swap version"
  echo ""
  echo -e "  ${BOLD}OPTIONS${RESET}"
  echo "    -v, --verbose   Show extra detail"
  echo "    -h, --help      Show this help"
  echo ""
  echo -e "  ${BOLD}PATHS${RESET}"
  echo "    Config:  $CONFIG"
  echo "    Log:     $LOG_FILE"
  echo "    Plist:   $PLIST_PATH"
  echo "    API:     http://${LISTEN}/v1"
  echo "    UI:      http://${LISTEN}"
  echo ""
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

case "$CMD" in
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  restart)   cmd_restart ;;
  status)    cmd_status ;;
  enable)    cmd_enable ;;
  disable)   cmd_disable ;;
  install)   cmd_install ;;
  uninstall) cmd_uninstall ;;
  logs)      cmd_logs "$@" ;;
  upgrade)   cmd_upgrade ;;
  version)   cmd_version ;;
  models)    cmd_models ;;
  comfyui)   cmd_comfyui "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    err "Unknown command: '$CMD'"
    echo "Run 'llamactl help' for usage." >&2
    exit 1
    ;;
esac
